# Copy to `.env` (gitignored) and fill in before `docker compose up`.
# Docker Compose reads this directory's `.env` to substitute the ${VAR} values
# in the compose files. The server itself does not load a dotenv file.

# --- Auth secrets ----------------------------------------------------------
# AUTH_SECRET is effectively required: without it the /auth routes fail, so the
# SPA cannot read its session back and mints a fresh guest on every visit. The
# Google credentials are only needed for Google sign-in (and guest claiming);
# guest play works end to end without them.

# Random 32+ byte string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   (or: openssl rand -hex 32)
AUTH_SECRET=

# Google OAuth client credentials. Create a Web application client in the
# Google Cloud Console with authorized redirect URI:
#   http://localhost:8080/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Optional overrides (override-file defaults are fine for local dev) ---
# These deviate from the localhost defaults in docker-compose.override.yml.
# Puzzle id and asset base are baked into the server image; change those in
# packages/server/Dockerfile, not here.

# Generation seed: the anti-solving secret (drives geometry, the scatter, and the
# wire id permutation). Unlike the puzzle id / asset base above, it is NOT baked
# into the image. The override file defaults it to synthetic-1m's seed, which
# matches the synthetic-1m R2 assets the dev server fetches, so leave it unset for
# normal local dev. Set it only if you slice your own local puzzle, to the SAME
# value you passed the slicer's --seed. In prod it is a Coolify service secret,
# never committed.
# MPP_GENERATION_SEED=

# Comma-separated allowed Origin headers. Empty = wildcard (dev only).
# MPP_ALLOWED_ORIGINS=
# AUTH_URL=http://localhost:8080
# AUTH_COOKIE_DOMAIN=
# MPP_APP_ORIGIN=http://localhost:5173

# Frontend (Vite) container overrides.
# VITE_WS_URL=
# VITE_AUTH_BASE_URL=
# MPP_ALLOWED_HOSTS=

# --- Production backups (set in Coolify, not used by local dev) -----------
# The backup sidecar pushes a Mongo dump + Redis RDB to a private R2 bucket.
# Local dev disables the loop (MPP_BACKUP_ENABLED=0 in the override file). These
# are the prod values, set in the Coolify service env: the keys are secrets and
# the endpoint carries the R2 account id, so none are committed.
# MPP_BACKUP_BUCKET=mpp-backups
# RCLONE_CONFIG_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# RCLONE_CONFIG_R2_ACCESS_KEY_ID=
# RCLONE_CONFIG_R2_SECRET_ACCESS_KEY=
