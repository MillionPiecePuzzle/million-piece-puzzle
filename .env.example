# Copy to `.env` (gitignored) and fill in before `docker compose up`.
# Docker Compose reads this directory's `.env` to substitute the ${VAR} values
# in the compose files. The server itself does not load a dotenv file.

# --- Required for contributor sign-in -------------------------------------
# Without these the server still boots and spectator mode works; only the
# authenticated WebSocket (contribution) is unavailable.

# Random 32+ byte string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   (or: openssl rand -hex 32)
AUTH_SECRET=

# Google OAuth client credentials. Create a Web application client in the
# Google Cloud Console with authorized redirect URI:
#   http://localhost:8080/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Optional overrides (override-file defaults are fine for local dev) ---
# These deviate from the localhost defaults in docker-compose.override.yml.
# Puzzle id and asset base are baked into the server image; change those in
# packages/server/Dockerfile, not here.

# Comma-separated allowed Origin headers. Empty = wildcard (dev only).
# MPP_ALLOWED_ORIGINS=
# AUTH_URL=http://localhost:8080
# AUTH_COOKIE_DOMAIN=
# MPP_APP_ORIGIN=http://localhost:5173

# Frontend (Vite) container overrides.
# VITE_WS_URL=
# VITE_AUTH_BASE_URL=
# MPP_ALLOWED_HOSTS=
