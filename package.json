{
  "name": "million-piece-puzzle",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A community-built online jigsaw puzzle: 1,000,000 pieces on a single shared canvas.",
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @mpp/shared && npm run build -w @mpp/server && npm run build -w @mpp/frontend",
    "typecheck": "npm run build -w @mpp/shared && npm run typecheck -w @mpp/server && npm run typecheck -w @mpp/frontend",
    "clean": "npm run clean --workspaces --if-present",
    "dev:frontend": "npm run dev -w @mpp/frontend",
    "dev:server": "npm run dev -w @mpp/server",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vue-eslint-parser": "^9.4.3"
  }
}
